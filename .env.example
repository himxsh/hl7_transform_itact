# CORS: comma-separated origins allowed to access the API
CORS_ORIGINS=http://localhost:3000

# Admin token for destructive operations (e.g. clearing audit logs)
ADMIN_TOKEN=change-me-in-production

# Maximum upload file size in MB (applies to both MIMIC and Generic modes)
MAX_UPLOAD_MB=5

# Encryption keys — MUST be set in production (IT Act §43A / DPDP §8(7))
# Without these, the pipeline falls back to insecure demo keys
HL7_HMAC_KEY=your-secure-hmac-secret-here
HL7_AES_KEY=your-secure-aes-secret-here
