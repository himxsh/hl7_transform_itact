                <mxCell id="title" value="Secure HL7 Orchestration Pipeline - Project Call Flow" style="text;html=0;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="400" y="30" width="800" height="40" as="geometry"/>
