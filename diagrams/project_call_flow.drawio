                <mxCell id="preprocess" value="2. Preprocessing&#xa;• Clean data&#xa;• Merge required fields&#xa;• Sample records" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;fontStyle=1;align=left;spacingLeft=12;spacingTop=10" parent="1" vertex="1">
                    <mxGeometry x="360" y="180" width="220" height="110" as="geometry"/>
