                <mxCell id="source" value="1. Input Data&#xa;• MIMIC-IV dataset&#xa;• Generic CSV upload" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;fontStyle=1;align=left;spacingLeft=12;spacingTop=10" parent="1" vertex="1">
