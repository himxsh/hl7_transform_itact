                <mxCell id="transform" value="3. HL7 Mapping Engine&#xa;• Build ORU^R01 message&#xa;• Generate MSH / PID / OBR / OBX" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;fontStyle=1;align=left;spacingLeft=12;spacingTop=10" parent="1" vertex="1">
                    <mxGeometry x="640" y="180" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="privacy" value="4. Privacy Layer&#xa;• Pseudonymize patient identity&#xa;• Scrub PII from notes&#xa;• DPDP-aligned anonymization" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;fontStyle=1;align=left;spacingLeft=12;spacingTop=10" parent="1" vertex="1">
                    <mxGeometry x="950" y="180" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="integrity" value="5. Security Layer&#xa;• SHA-256 hashing&#xa;• Add ZSH integrity segment&#xa;• Tamper-evident sealing" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;fontStyle=1;align=left;spacingLeft=12;spacingTop=10" parent="1" vertex="1">
